<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>JPMD Local Builder</title>
    <style>
      :root {
        --paper: #f5efe2;
        --paper-deep: #e6dcc8;
        --ink: #1d1a16;
        --muted: #6b6054;
        --accent: #9d3b1f;
        --accent-soft: #edd2c8;
        --line: rgba(29, 26, 22, 0.14);
        --panel: rgba(255, 251, 245, 0.86);
        --shadow: 0 24px 60px rgba(52, 37, 21, 0.12);
      }

      * { box-sizing: border-box; }
      body {
        margin: 0;
        color: var(--ink);
        font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, "URW Palladio L", serif;
        background:
          radial-gradient(circle at top left, rgba(157, 59, 31, 0.10), transparent 28%),
          linear-gradient(135deg, #f8f2e7 0%, #efe4d1 52%, #eadbc5 100%);
        min-height: 100vh;
      }

      .shell {
        max-width: 1240px;
        margin: 0 auto;
        padding: 40px 24px 64px;
      }

      .masthead {
        display: grid;
        gap: 12px;
        margin-bottom: 28px;
      }

      .eyebrow {
        color: var(--accent);
        font-size: 0.78rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-size: clamp(2.4rem, 4vw, 4.5rem);
        line-height: 0.95;
        letter-spacing: -0.04em;
      }

      .lede {
        max-width: 64rem;
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.7;
        margin: 0;
      }

      .layout {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.8fr);
        gap: 24px;
        align-items: start;
      }

      .card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 24px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(12px);
      }

      .builder {
        padding: 28px;
      }

      .sidebar {
        padding: 24px;
        display: grid;
        gap: 18px;
      }

      .stack {
        display: grid;
        gap: 22px;
      }

      h2, h3 {
        margin: 0;
        letter-spacing: -0.02em;
      }

      h2 { font-size: 1.5rem; }
      h3 { font-size: 1.1rem; }

      .note,
      .helper,
      .mini {
        color: var(--muted);
        line-height: 1.6;
      }

      .helper { font-size: 0.95rem; }
      .mini { font-size: 0.9rem; }

      .error {
        margin-bottom: 20px;
        padding: 16px 18px;
        border-radius: 18px;
        border: 1px solid rgba(157, 59, 31, 0.24);
        background: var(--accent-soft);
      }

      .error strong {
        display: block;
        margin-bottom: 6px;
      }

      form {
        display: grid;
        gap: 22px;
      }

      .mode-grid,
      .field-grid {
        display: grid;
        gap: 14px;
      }

      .mode-grid {
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      }

      .field-grid.compact {
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      }

      .field-grid.kanbun {
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      }

      .asset-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 16px;
      }

      .asset-group {
        display: grid;
        gap: 14px;
        padding: 18px;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.46);
      }

      .asset-modes {
        grid-template-columns: 1fr;
      }

      .mode-tile {
        position: relative;
        display: grid;
        gap: 10px;
        padding: 16px;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.52);
      }

      .mode-tile input {
        position: absolute;
        inset: 16px auto auto 16px;
      }

      .mode-copy {
        padding-left: 28px;
      }

      .mode-copy strong {
        display: block;
        margin-bottom: 4px;
      }

      label {
        display: grid;
        gap: 6px;
        font-size: 0.92rem;
        color: var(--muted);
      }

      input[type="text"],
      input[type="number"],
      input[type="file"],
      select,
      textarea {
        width: 100%;
        border: 1px solid rgba(29, 26, 22, 0.18);
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.84);
        padding: 12px 14px;
        color: var(--ink);
        font: inherit;
      }

      textarea {
        min-height: 320px;
        resize: vertical;
        line-height: 1.6;
      }

      input:disabled,
      textarea:disabled {
        background: rgba(238, 231, 220, 0.62);
        color: rgba(29, 26, 22, 0.52);
      }

      .source-pane {
        display: grid;
        gap: 10px;
      }

      .source-pane[hidden] {
        display: none;
      }

      .selection-meta {
        display: grid;
        gap: 4px;
        padding: 14px 16px;
        border-radius: 16px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.46);
      }

      .section-head {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: end;
      }

      details {
        border-top: 1px solid var(--line);
        padding-top: 18px;
      }

      details summary {
        cursor: pointer;
        font-weight: 700;
        list-style: none;
      }

      details summary::-webkit-details-marker {
        display: none;
      }

      .details-body {
        display: grid;
        gap: 20px;
        padding-top: 18px;
      }

      .kanbun-group {
        display: grid;
        gap: 12px;
        padding: 16px;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.46);
      }

      .build-bar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 16px;
        padding-top: 8px;
      }

      button {
        border: 0;
        border-radius: 999px;
        padding: 14px 22px;
        background: linear-gradient(135deg, #8b2e15, #b84d1d);
        color: #fff8f3;
        font: inherit;
        font-weight: 700;
        letter-spacing: 0.01em;
        cursor: pointer;
        box-shadow: 0 16px 28px rgba(157, 59, 31, 0.24);
      }

      code, pre {
        font-family: "Berkeley Mono", "Iosevka Term", "SFMono-Regular", Consolas, monospace;
      }

      .spec-list {
        display: grid;
        gap: 12px;
      }

      .spec {
        padding: 14px 16px;
        border-radius: 16px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.52);
      }

      .spec strong {
        display: block;
        margin-bottom: 4px;
      }

      .sample-list {
        display: grid;
        gap: 12px;
      }

      .sample-card {
        display: grid;
        gap: 6px;
        padding: 14px 16px;
        border-radius: 16px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.52);
      }

      .sample-card.is-selected {
        border-color: rgba(157, 59, 31, 0.34);
        box-shadow: inset 0 0 0 1px rgba(157, 59, 31, 0.12);
      }

      @media (max-width: 960px) {
        .layout {
          grid-template-columns: 1fr;
        }

        .builder,
        .sidebar {
          padding: 22px;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="masthead">
        <div class="eyebrow">Local PDF Builder</div>
        <h1>Paste Markdown. Tune the grid. Download the PDF.</h1>
        <p class="lede">This local Sinatra app now starts from bundled sample documents, lets you swap bundled or uploaded Zotero and CSL assets, and keeps the full page plus kanbun geometry controls in one browser flow.</p>
      </header>
      <%= yield %>
    </div>
    <script>
      (function () {
        function updateModeGroup(group, defaultValue) {
          var selected = document.querySelector('input[name="' + group + '_mode"]:checked');
          var mode = selected ? selected.value : defaultValue;

          document.querySelectorAll('[data-pane-group="' + group + '"]').forEach(function (pane) {
            var active = pane.getAttribute('data-pane-value') === mode;
            pane.hidden = !active;
            pane.querySelectorAll('textarea, input[type="file"], select').forEach(function (field) {
              field.disabled = !active;
            });
          });
        }

        ['source', 'bibliography', 'csl'].forEach(function (group) {
          document.querySelectorAll('input[name="' + group + '_mode"]').forEach(function (input) {
            input.addEventListener('change', function () {
              updateModeGroup(group, group === 'source' ? 'sample' : 'sample');
            });
          });
        });

        updateModeGroup('source', 'sample');
        updateModeGroup('bibliography', 'sample');
        updateModeGroup('csl', 'sample');
      }());
    </script>
  </body>
</html>

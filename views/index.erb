<div class="layout">
  <main class="builder card">
    <% if @error_message %>
      <div class="error">
        <strong>Build failed</strong>
        <div><%= h(@error_message) %></div>
      </div>
    <% end %>

    <form action="/build" method="post" enctype="multipart/form-data">
      <section class="stack">
        <div class="section-head">
          <div>
            <h2>Source</h2>
            <p class="helper">Start from a bundled sample, paste Markdown directly, or upload a Markdown file.</p>
          </div>
        </div>
        <div class="mode-grid">
          <label class="mode-tile">
            <input type="radio" name="source_mode" value="sample" <%= "checked" if source_mode?("sample") %>>
            <div class="mode-copy">
              <strong>Bundled Sample</strong>
              <span>Use a repo sample and build immediately without preparing any files.</span>
            </div>
          </label>
          <label class="mode-tile">
            <input type="radio" name="source_mode" value="paste" <%= "checked" if source_mode?("paste") %>>
            <div class="mode-copy">
              <strong>Paste Markdown</strong>
              <span>Use the textarea below and compile the pasted content directly.</span>
            </div>
          </label>
          <label class="mode-tile">
            <input type="radio" name="source_mode" value="upload" <%= "checked" if source_mode?("upload") %>>
            <div class="mode-copy">
              <strong>Upload Markdown File</strong>
              <span>Accepts <code>.md</code> or <code>.markdown</code> as UTF-8 text.</span>
            </div>
          </label>
        </div>

        <div class="source-pane" data-pane-group="source" data-pane-value="sample">
          <label>
            Bundled Sample Document
            <select name="source_sample">
              <% source_samples.each do |key, sample| %>
                <option value="<%= h(key) %>" <%= "selected" if state_value("source_sample") == key %>><%= h(sample.fetch("label")) %></option>
              <% end %>
            </select>
          </label>
          <div class="selection-meta">
            <strong><%= h(selected_source_sample.fetch("label")) %></strong>
            <span class="note"><%= h(selected_source_sample.fetch("description")) %></span>
            <code><%= h(selected_source_sample.fetch("path")) %></code>
          </div>
          <p class="mini">Bundled sample content is shown below as a readonly template you can copy and adapt.</p>
          <% source_samples.each do |key, sample| %>
            <section class="sample-preview" data-preview-group="source" data-preview-value="<%= h(key) %>">
              <div class="preview-head">
                <strong><%= h(sample.fetch("label")) %> Markdown</strong>
                <span class="note">Readonly reference content from <code><%= h(sample.fetch("path")) %></code></span>
              </div>
              <textarea class="sample-preview-text" readonly spellcheck="false"><%= h(sample_file_content(sample.fetch("path"))) %></textarea>
            </section>
          <% end %>
        </div>

        <div class="source-pane" data-pane-group="source" data-pane-value="paste">
          <label>
            Markdown Text
            <textarea name="markdown_text" spellcheck="false"><%= h(state_value("markdown_text")) %></textarea>
          </label>
          <p class="mini">Use the citation section below if you want bundled or uploaded bibliography files without editing frontmatter by hand.</p>
        </div>

        <div class="source-pane" data-pane-group="source" data-pane-value="upload">
          <label>
            Markdown File
            <input type="file" name="markdown_file" accept=".md,.markdown,text/markdown,text/plain">
          </label>
          <p class="mini">
            <% if state_value("upload_filename").to_s.empty? %>
              No file selected yet.
            <% else %>
              Last selected file: <strong><%= h(state_value("upload_filename")) %></strong>
            <% end %>
          </p>
        </div>
      </section>

      <section class="stack">
        <div class="section-head">
          <div>
            <h2>Citation Assets</h2>
            <p class="helper">Choose bundled citation samples, upload your own Zotero/BibTeX or CSL files, or keep whatever the Markdown already declares.</p>
          </div>
        </div>

        <div class="asset-grid">
          <section class="asset-group">
            <h3>Bibliography</h3>
            <div class="mode-grid asset-modes">
              <label class="mode-tile">
                <input type="radio" name="bibliography_mode" value="sample" <%= "checked" if bibliography_mode?("sample") %>>
                <div class="mode-copy">
                  <strong>Bundled Sample</strong>
                  <span>Default general Zotero JSON/BibTeX samples are ready to use.</span>
                </div>
              </label>
              <label class="mode-tile">
                <input type="radio" name="bibliography_mode" value="upload" <%= "checked" if bibliography_mode?("upload") %>>
                <div class="mode-copy">
                  <strong>Upload Bibliography</strong>
                  <span>Accepts <code>.json</code> or <code>.bib</code>.</span>
                </div>
              </label>
              <label class="mode-tile">
                <input type="radio" name="bibliography_mode" value="keep" <%= "checked" if bibliography_mode?("keep") %>>
                <div class="mode-copy">
                  <strong>Keep Markdown Setting</strong>
                  <span>Use the bibliography path already written in the Markdown itself.</span>
                </div>
              </label>
            </div>

            <div class="source-pane" data-pane-group="bibliography" data-pane-value="sample">
              <label>
                Bundled Bibliography Sample
                <select name="bibliography_sample">
                  <% bibliography_samples.each do |key, sample| %>
                    <option value="<%= h(key) %>" <%= "selected" if state_value("bibliography_sample") == key %>><%= h(sample.fetch("label")) %></option>
                  <% end %>
                </select>
              </label>
              <div class="selection-meta">
                <strong><%= h(selected_bibliography_sample.fetch("label")) %></strong>
                <span class="note"><%= h(selected_bibliography_sample.fetch("note")) %></span>
                <code><%= h(selected_bibliography_sample.fetch("workspace_path")) %></code>
              </div>
              <p class="mini">Use the bundled bibliography below as a reference for how your own JSON or BibTeX file can be structured.</p>
              <% bibliography_samples.each do |key, sample| %>
                <section class="sample-preview" data-preview-group="bibliography" data-preview-value="<%= h(key) %>">
                  <div class="preview-head">
                    <strong><%= h(sample.fetch("label")) %></strong>
                    <span class="note">Readonly reference content from <code><%= h(sample.fetch("workspace_path")) %></code></span>
                  </div>
                  <textarea class="sample-preview-text" readonly spellcheck="false"><%= h(sample_file_content(sample.fetch("workspace_path"))) %></textarea>
                </section>
              <% end %>
            </div>

            <div class="source-pane" data-pane-group="bibliography" data-pane-value="upload">
              <label>
                Bibliography File
                <input type="file" name="bibliography_file" accept=".json,.bib,application/json,text/plain,text/x-bibtex,application/x-bibtex">
              </label>
              <p class="mini">
                <% if state_value("bibliography_upload_filename").to_s.empty? %>
                  No bibliography file selected yet.
                <% else %>
                  Last selected bibliography: <strong><%= h(state_value("bibliography_upload_filename")) %></strong>
                <% end %>
              </p>
            </div>

            <div class="source-pane" data-pane-group="bibliography" data-pane-value="keep">
              <p class="mini">No web override will be applied. The Markdown’s own <code>bibliography:</code> metadata stays in control.</p>
            </div>
          </section>

          <section class="asset-group">
            <h3>CSL Style</h3>
            <div class="mode-grid asset-modes">
              <label class="mode-tile">
                <input type="radio" name="csl_mode" value="sample" <%= "checked" if csl_mode?("sample") %>>
                <div class="mode-copy">
                  <strong>Bundled Sample</strong>
                  <span>Start with the general bundled CSL, or compare it with the older custom style.</span>
                </div>
              </label>
              <label class="mode-tile">
                <input type="radio" name="csl_mode" value="upload" <%= "checked" if csl_mode?("upload") %>>
                <div class="mode-copy">
                  <strong>Upload CSL</strong>
                  <span>Accepts a local <code>.csl</code> file.</span>
                </div>
              </label>
              <label class="mode-tile">
                <input type="radio" name="csl_mode" value="keep" <%= "checked" if csl_mode?("keep") %>>
                <div class="mode-copy">
                  <strong>Keep Markdown Setting</strong>
                  <span>Use the <code>csl:</code> path already written in the Markdown.</span>
                </div>
              </label>
            </div>

            <div class="source-pane" data-pane-group="csl" data-pane-value="sample">
              <label>
                Bundled CSL Sample
                <select name="csl_sample">
                  <% csl_samples.each do |key, sample| %>
                    <option value="<%= h(key) %>" <%= "selected" if state_value("csl_sample") == key %>><%= h(sample.fetch("label")) %></option>
                  <% end %>
                </select>
              </label>
              <div class="selection-meta">
                <strong><%= h(selected_csl_sample.fetch("label")) %></strong>
                <span class="note"><%= h(selected_csl_sample.fetch("note")) %></span>
                <code><%= h(selected_csl_sample.fetch("workspace_path")) %></code>
              </div>
              <p class="mini">The bundled CSL is also shown directly so users can inspect the XML structure before uploading their own style file.</p>
              <% csl_samples.each do |key, sample| %>
                <section class="sample-preview" data-preview-group="csl" data-preview-value="<%= h(key) %>">
                  <div class="preview-head">
                    <strong><%= h(sample.fetch("label")) %></strong>
                    <span class="note">Readonly reference content from <code><%= h(sample.fetch("workspace_path")) %></code></span>
                  </div>
                  <textarea class="sample-preview-text" readonly spellcheck="false"><%= h(sample_file_content(sample.fetch("workspace_path"))) %></textarea>
                </section>
              <% end %>
            </div>

            <div class="source-pane" data-pane-group="csl" data-pane-value="upload">
              <label>
                CSL File
                <input type="file" name="csl_file" accept=".csl,text/plain,text/xml,application/xml,application/csl+xml,application/vnd.citationstyles.style+xml">
              </label>
              <p class="mini">
                <% if state_value("csl_upload_filename").to_s.empty? %>
                  No CSL file selected yet.
                <% else %>
                  Last selected CSL: <strong><%= h(state_value("csl_upload_filename")) %></strong>
                <% end %>
              </p>
            </div>

            <div class="source-pane" data-pane-group="csl" data-pane-value="keep">
              <p class="mini">No web override will be applied. The Markdown’s own <code>csl:</code> metadata stays in control.</p>
            </div>
          </section>
        </div>
      </section>

      <section class="stack">
        <div class="section-head">
          <div>
            <h2>Page Controls</h2>
            <p class="helper">These are the common parameters you usually adjust first.</p>
          </div>
        </div>
        <div class="field-grid compact">
          <label>
            Top Margin
            <input type="text" name="overrides[layout][margins][top]" value="<%= h(state_value("overrides", "layout", "margins", "top")) %>">
          </label>
          <label>
            Right Margin
            <input type="text" name="overrides[layout][margins][right]" value="<%= h(state_value("overrides", "layout", "margins", "right")) %>">
          </label>
          <label>
            Bottom Margin
            <input type="text" name="overrides[layout][margins][bottom]" value="<%= h(state_value("overrides", "layout", "margins", "bottom")) %>">
          </label>
          <label>
            Left Margin
            <input type="text" name="overrides[layout][margins][left]" value="<%= h(state_value("overrides", "layout", "margins", "left")) %>">
          </label>
          <label>
            Characters Per Line
            <input type="number" min="2" name="overrides[layout][grid][characters_per_line]" value="<%= h(state_value("overrides", "layout", "grid", "characters_per_line")) %>">
          </label>
          <label>
            Lines Per Page
            <input type="number" min="1" name="overrides[layout][grid][lines_per_page]" value="<%= h(state_value("overrides", "layout", "grid", "lines_per_page")) %>">
          </label>
          <label>
            Body Font Size
            <input type="text" name="overrides[layout][font][body_size]" value="<%= h(state_value("overrides", "layout", "font", "body_size")) %>">
          </label>
        </div>
      </section>

      <details <%= "open" if advanced_open? %>>
        <summary>Advanced Kanbun Controls</summary>
        <div class="details-body">
          <section class="kanbun-group">
            <h3>Side Notes</h3>
            <div class="field-grid kanbun">
              <label>
                Side Gap
                <input type="text" name="overrides[kanbun][side][gap]" value="<%= h(state_value("overrides", "kanbun", "side", "gap")) %>">
              </label>
              <label>
                Side Min Width
                <input type="text" name="overrides[kanbun][side][min_width]" value="<%= h(state_value("overrides", "kanbun", "side", "min_width")) %>">
              </label>
            </div>
          </section>

          <% [["furigana", "Furigana"], ["kaeriten", "Kaeriten"], ["okurigana", "Okurigana"]].each do |key, label| %>
            <section class="kanbun-group">
              <h3><%= label %></h3>
              <div class="field-grid kanbun">
                <label>
                  Size
                  <input type="text" name="overrides[kanbun][<%= key %>][size]" value="<%= h(state_value("overrides", "kanbun", key, "size")) %>">
                </label>
                <label>
                  Shift Up
                  <input type="text" name="overrides[kanbun][<%= key %>][shift][up]" value="<%= h(state_value("overrides", "kanbun", key, "shift", "up")) %>">
                </label>
                <label>
                  Shift Right
                  <input type="text" name="overrides[kanbun][<%= key %>][shift][right]" value="<%= h(state_value("overrides", "kanbun", key, "shift", "right")) %>">
                </label>
                <label>
                  Shift Down
                  <input type="text" name="overrides[kanbun][<%= key %>][shift][down]" value="<%= h(state_value("overrides", "kanbun", key, "shift", "down")) %>">
                </label>
                <label>
                  Shift Left
                  <input type="text" name="overrides[kanbun][<%= key %>][shift][left]" value="<%= h(state_value("overrides", "kanbun", key, "shift", "left")) %>">
                </label>
              </div>
            </section>
          <% end %>
        </div>
      </details>

      <div class="build-bar">
        <button type="submit">Build PDF</button>
        <div class="mini">Build precedence is: built-in preset → repo <code>jpmd.yml</code> → Markdown frontmatter → web form overrides. Bundled or uploaded citation assets override Markdown only when selected above.</div>
      </div>
    </form>
  </main>

  <aside class="sidebar card">
    <section class="spec-list">
      <div class="spec">
        <strong>First-run friendly</strong>
        <span class="note">The default page opens on the bundled academic sample with a general Zotero JSON file and a general CSL already selected.</span>
      </div>
      <div class="spec">
        <strong>Custom uploads stay local</strong>
        <span class="note">Uploaded Markdown, bibliography, and CSL files are written into a temp workspace for that one request only.</span>
      </div>
      <div class="spec">
        <strong>Bundled references still resolve</strong>
        <span class="note">The app copies the repo’s <code>references/</code> directory into each build workspace so the bundled sample documents keep working.</span>
      </div>
      <div class="spec">
        <strong>Custom citation pack included</strong>
        <span class="note">The older Japanese-focused Zotero and CSL samples remain available under the bundled sample selectors, but they are no longer the default testing path.</span>
      </div>
    </section>

    <section class="stack">
      <h2>Bundled Sample Documents</h2>
      <div class="sample-list">
        <% source_samples.each do |key, sample| %>
          <article class="sample-card <%= "is-selected" if state_value("source_sample") == key %>">
            <strong><%= h(sample.fetch("label")) %></strong>
            <span class="note"><%= h(sample.fetch("description")) %></span>
            <code><%= h(sample.fetch("path")) %></code>
          </article>
        <% end %>
      </div>
    </section>

    <section class="stack">
      <h2>Bundled Citation Packs</h2>
      <div class="sample-list">
        <article class="sample-card">
          <strong>Default General Pack</strong>
          <span class="note">Uses the bundled general Zotero export and Chicago notes bibliography CSL.</span>
          <code>references/zotero-export.json</code>
          <code>references/chicago-notes-bibliography.csl</code>
        </article>
        <article class="sample-card">
          <strong>Reference-Only Custom Pack</strong>
          <span class="note">Keeps the earlier Japanese-focused Zotero and CSL samples available for comparison.</span>
          <code>references/custom/japanese-note-sample.json</code>
          <code>references/custom/word-japanese-note.csl</code>
        </article>
      </div>
    </section>
  </aside>
</div>

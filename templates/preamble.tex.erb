\usepackage[match]{luatexja-fontspec}
\renewcommand{\jlreqkanjiskip}{<%= kanjiskip %> plus 0.1pt minus 0.1pt}
\setmainfont{Times New Roman}
\setmainjfont[
  BoldFont={MS Mincho},
  BoldFeatures={FakeBold=2}
]{MS Mincho}

\usepackage{titlesec}
\titleformat{\section}{\normalfont\bfseries}{\thesection}{1em}{}
\titlespacing*{\section}{0pt}{1\baselineskip}{0pt}

\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancyfoot[C]{{\rmfamily\fontsize{10pt}{10pt}\selectfont\thepage}}
\interfootnotelinepenalty=10000
\makeatletter
\renewcommand{\thefootnote}{\arabic{footnote}}
\renewcommand{\@makefnmark}{\hbox{\@textsuperscript{\normalfont\@thefnmark}}}
\long\def\@makefntext#1{%
  \begingroup
  \ltjsetparameter{kanjiskip=0pt plus .25\zw minus 0pt}%
  \parindent 1em%
  \noindent
  \hb@xt@3em{\hss\@makefnmark\hspace{0.8em}}#1%
  \par
  \endgroup
}
\renewcommand{\footnoterule}{%
  \kern -3pt
  \hrule width 0.38\columnwidth
  \kern 2.6pt
}
\makeatother
\fancypagestyle{plain}{
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
  \fancyfoot[C]{{\rmfamily\fontsize{10pt}{10pt}\selectfont\thepage}}
}


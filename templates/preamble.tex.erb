\usepackage{luatexja-ruby}
\newsavebox{\kanbunbasebox}
\newsavebox{\kanbunmainbox}
\newsavebox{\kanbunfuriganabox}
\newsavebox{\kanbunkaeribox}
\newsavebox{\kanbunokuribox}
\newcommand{\kanbunifempty}[3]{\if\relax\detokenize{#1}\relax#2\else#3\fi}
\newcommand{\kanbunfuriganafont}{\fontsize{<%= furigana_size %>}{<%= furigana_size %>}\selectfont}
\newcommand{\kanbunkaeritenfont}{\fontsize{<%= kaeriten_size %>}{<%= kaeriten_size %>}\selectfont}
\newcommand{\kanbunokuriganafont}{\fontsize{<%= okurigana_size %>}{<%= okurigana_size %>}\selectfont}
\newcommand{\kanbunsidegap}{<%= side_gap %>}
\newcommand{\kanbunsideminwidth}{<%= side_min_width %>}
\newcommand{\kanbunfuriganashiftx}{\dimexpr <%= furigana_right %> - <%= furigana_left %>\relax}
\newcommand{\kanbunfuriganashifty}{\dimexpr <%= furigana_up %> - <%= furigana_down %>\relax}
\newcommand{\kanbunkaeritenshiftx}{\dimexpr <%= kaeriten_right %> - <%= kaeriten_left %>\relax}
\newcommand{\kanbunkaeritenshifty}{\dimexpr <%= kaeriten_up %> - <%= kaeriten_down %>\relax}
\newcommand{\kanbunkaeritenshiftleft}{<%= kaeriten_left %>}
\newcommand{\kanbunkaeritenshiftright}{<%= kaeriten_right %>}
\newcommand{\kanbunokuriganashiftx}{\dimexpr <%= okurigana_right %> - <%= okurigana_left %>\relax}
\newcommand{\kanbunokuriganashifty}{\dimexpr <%= okurigana_up %> - <%= okurigana_down %>\relax}
\newcommand{\kanbunokuriganishiftleft}{<%= okurigana_left %>}
\newcommand{\kanbunokuriganishiftright}{<%= okurigana_right %>}
\newcommand{\kanbunplacewithin}[3]{%
  \hbox to #1{%
    \hss
    \rlap{\hskip #2\relax #3}%
    \hss
  }%
}
\newcommand{\kanbunbuildmainbox}[2]{%
  \kanbunifempty{#2}{%
    \sbox{\kanbunmainbox}{#1}%
  }{%
    \sbox{\kanbunfuriganabox}{{\kanbunfuriganafont #2}}%
    \sbox{\kanbunmainbox}{%
      \ruby{#1}{%
        \kanbunplacewithin{\wd\kanbunfuriganabox}{\kanbunfuriganashiftx}{%
          \raisebox{\kanbunfuriganashifty}[0pt][0pt]{\usebox{\kanbunfuriganabox}}%
        }%
      }%
    }%
  }%
}
\newcommand{\kanbun}[4]{%
  \leavevmode
  \begingroup
  \sbox{\kanbunbasebox}{#1}%
  \kanbunbuildmainbox{#1}{#2}%
  \kanbunifempty{#3#4}{%
    \usebox{\kanbunmainbox}%
  }{%
    \sbox{\kanbunkaeribox}{{\kanbunkaeritenfont #4}}%
    \sbox{\kanbunokuribox}{{\kanbunokuriganafont #3}}%
    \dimen0=\kanbunsideminwidth\relax
    \kanbunifempty{#4}{}{%
      \dimen2=\dimexpr\wd\kanbunkaeribox+\kanbunkaeritenshiftleft+\kanbunkaeritenshiftright\relax
      \ifdim\dimen2>\dimen0
        \dimen0=\dimen2
      \fi
    }%
    \kanbunifempty{#3}{}{%
      \dimen2=\dimexpr\wd\kanbunokuribox+\kanbunokuriganishiftleft+\kanbunokuriganishiftright\relax
      \ifdim\dimen2>\dimen0
        \dimen0=\dimen2
      \fi
    }%
    \hbox{%
      \usebox{\kanbunmainbox}%
      \kern\kanbunsidegap\relax
      \hbox to \dimen0{%
        \kanbunifempty{#4}{}{%
          \rlap{%
            \raisebox{\dimexpr\ht\kanbunbasebox-.5\ht\kanbunkaeribox+.5\dp\kanbunkaeribox+\kanbunkaeritenshifty\relax}[0pt][0pt]{%
              \kanbunplacewithin{\dimen0}{\kanbunkaeritenshiftx}{\usebox{\kanbunkaeribox}}%
            }%
          }%
        }%
        \kanbunifempty{#3}{}{%
          \rlap{%
            \raisebox{\dimexpr-\dp\kanbunbasebox-.5\ht\kanbunokuribox+.5\dp\kanbunokuribox+\kanbunokuriganashifty\relax}[0pt][0pt]{%
              \kanbunplacewithin{\dimen0}{\kanbunokuriganashiftx}{\usebox{\kanbunokuribox}}%
            }%
          }%
        }%
        \hss
      }%
    }%
  }%
  \endgroup
}
